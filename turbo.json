{
    "$schema": "https://turbo.build/schema.json",
    "tasks":{
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "test": {
            "dependsOn": ["^build"]
        },
        "clean": {"cache": false},
        "db:generate": {"cache": false},
        "db:migrate": {"cache": false},
        "db:studio": {"cache": false, "persistent": true},
        "db:seed": {"cache": false}
    }
}
