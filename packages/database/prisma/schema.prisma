generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    id        String   @id @default(uuid())
    email     String   @unique
    name      String?
    role      String   @default("USER")
    orders    Order[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Product model
model Product {
    id        String   @id @default(uuid())
    name      String
    description String?
    price     Decimal @db.Decimal(10, 2)
    tax       Decimal @default(0.10) @db.Decimal(5, 3) //default 10% tax
    stock     Int   @default(0)
    orderItems OrderItem[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Order model
model Order {
    id        String   @id @default(uuid())
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String
    orderItems OrderItem[]
    subtotal   Decimal  @db.Decimal(12, 2)
    totalTax   Decimal  @db.Decimal(12, 2)
    totalPrice     Decimal  @db.Decimal(12, 2)
    status    String   @default("PENDING")  //PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// OrderItem model
model OrderItem {
    id        String   @id @default(uuid())
    orderId    String
    order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
    productId  String
    product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
    quantity   Int
    price      Decimal  @db.Decimal(10, 2) //price at the time of order
    tax        Decimal  @db.Decimal(5, 3) //tax at the time of order
    subtotal   Decimal  @db.Decimal(12, 2) //price * quantity
    taxAmount  Decimal  @db.Decimal(12, 2) //subtotal * tax
    total      Decimal  @db.Decimal(12, 2) //subtotal + taxAmount
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
